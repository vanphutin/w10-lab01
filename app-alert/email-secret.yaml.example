# Email credentials cho AlertManager
# KHÔNG commit file này vào Git! (add vào .gitignore)
# Replace password với Gmail App Password thật từ https://myaccount.google.com/apppasswords
apiVersion: v1
kind: Secret
metadata:
  name: alertmanager-email
  namespace: monitoring
type: Opaque
stringData:
  password: your-gmail-app-password-16-chars